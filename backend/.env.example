# ─── Server ────────────────────────────────────────────────
PORT=3000

# ─── MongoDB ───────────────────────────────────────────────
# Replace with your MongoDB Atlas connection string or local URI
MONGODB_URI=mongodb://localhost:27017/trustissues_foodedition

# ─── Redis (used by Bull Queue) ────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Google Cloud ──────────────────────────────────────────
# Path to your Google Cloud service-account key JSON file
GOOGLE_APPLICATION_CREDENTIALS=./path-to-your-service-account-key.json
